{
  "name": "@nikifutaki/ts-markdown",
  "version": "0.0.1",
  "description": "A simple markdown generator for TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "test": "bun test",
    "readme": "bun ./src/example.ts > README.md",
    "build": "tsc",
    "start": "bun run ./src/example.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikifutaki/ts-markdown.git"
  },
  "author": "nikifutaki",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nikifutaki/ts-markdown/issues"
  },
  "homepage": "https://github.com/nikifutaki/ts-markdown#readme",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.13.16",
    "bun-types": "latest",
    "typescript": "^5.8.2"
  }
}
